---
apiVersion: storage.k8s.io/v1
kind: StorageClass
metadata:
  name: ebs-sc
provisioner: ebs.csi.aws.com  #This tells Kubernetes to use the AWS EBS CSI (Container Storage Interface) driver to actually create the storage volume in AWS.

reclaimPolicy: Retain
volumeBindingMode: WaitForFirstConsumer  #“# Ensures EBS is provisioned in the same AZ as the pod- Don’t create the EBS volume until the Pod is scheduled.”

---

apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: ebs-dynamic
spec:
  storageClassName: "ebs-sc" 
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi


--- 
apiVersion: v1
kind: Pod
metadata:
  name: nginx-ebs-dynamic
  labels:
    app: nginx
spec:
  
  containers:
  - name: nginx
    image: nginx
    ports:
    - containerPort: 80
    
    volumeMounts:
    - name: ebs-dynamic
      mountPath: /usr/share/nginx/html

  volumes:
  - name: ebs-dynamic
    persistentVolumeClaim:
      claimName: ebs-dynamic

---
apiVersion: v1
kind: Service
metadata:
   name: nginx-svc
   labels:
     app: nginx

spec:
  type: LoadBalancer
  ports:
    - port: 80
      targetPort: 80 
      protocol: TCP

  selector:
      app: nginx 
