---
apiVersion: v1
kind: PersistentVolume
metadata:
  name: ebs-static
spec:
  accessModes:
  - ReadWriteOnce  ## Only one node (machine) can read and write to this volume at a time.
  capacity:
    storage: 20Gi
  csi:
    driver: ebs.csi.aws.com
    fsType: ext4
    volumeHandle: vol-0660b634160b24e6b
  # volumeHandle: vol-06a998872896a52a7

---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: ebs-static
spec:
  storageClassName: "" # An empty string means don’t use any default StorageClass.
  volumeName: ebs-static
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi

---
apiVersion: v1
kind: Pod
metadata:
  name: nginx
  labels:
    app: nginx 
spec:
  nodeSelector:
    topology.kubernetes.io/zone: us-east-1b
  # topology.kubernetes.io/zone=us-east-1b

  containers:
    - name: ngix 
      image: nginx
      ports:
        - containerPort: 80

      volumeMounts:
        - mountPath: /usr/share/nginx/html/
          name: ebs-static

  volumes:
    - name: ebs-static
      persistentVolumeClaim:
       claimName: ebs-static  
        


#### service manifest to expose nginx pod 
---
apiVersion: v1
kind: Service
metadata:
   name: nginx-svc
   labels:
     app: nginx

spec:
  type: LoadBalancer
  ports:
    - port: 80
      targetPort: 80 
      protocol: TCP

  selector:
      app: nginx 
